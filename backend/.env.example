SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_ANON_KEY=
SUPABASE_SECRET_KEY=
JWT_SECRET=

ANTHROPIC_API_KEY=

# Google OAuth for ComsOS is configured in Supabase Auth providers,
